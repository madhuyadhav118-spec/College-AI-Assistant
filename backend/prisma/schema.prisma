generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model departments {
  department_id   Int         @id @default(autoincrement())
  department_name String      @unique(map: "department_name") @db.VarChar(100)
  department_code String      @unique(map: "department_code") @db.VarChar(20)
  hod_name        String?     @db.VarChar(100)
  email           String?     @db.VarChar(100)
  phone           String?     @db.VarChar(15)
  building_name   String?     @db.VarChar(100)
  created_at      DateTime?   @default(now()) @db.Timestamp(0)
  updated_at      DateTime?   @default(now()) @db.Timestamp(0)
  course_id       Int?
  courses         courses?    @relation(fields: [course_id], references: [course_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_department_course")
  faculty         faculty[]
  students        students[]
  subjects        subjects[]
  timetable       timetable[]

  @@index([course_id], map: "fk_department_course")
}

model subjects {
  subject_id    Int            @id @default(autoincrement())
  subject_name  String         @db.VarChar(100)
  subject_code  String         @unique(map: "subject_code") @db.VarChar(20)
  department_id Int
  semester      Int
  year          Int
  credits       Int
  created_at    DateTime?      @default(now()) @db.Timestamp(0)
  updated_at    DateTime?      @default(now()) @db.Timestamp(0)
  examinations  examinations[]
  results       results[]
  departments   departments    @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_subject_department")
  timetable     timetable[]

  @@index([department_id], map: "fk_subject_department")
}

model courses {
  course_id      Int           @id @default(autoincrement())
  course_name    String        @db.VarChar(100)
  course_code    String        @unique(map: "course_code") @db.VarChar(20)
  duration_years Int
  created_at     DateTime?     @default(now()) @db.Timestamp(0)
  updated_at     DateTime?     @default(now()) @db.Timestamp(0)
  departments    departments[]
}

model faculty {
  faculty_id    Int             @id @default(autoincrement())
  user_id       Int
  employee_id   String          @unique(map: "employee_id") @db.VarChar(30)
  department    String          @db.VarChar(100)
  designation   String?         @db.VarChar(100)
  qualification String?         @db.VarChar(100)
  experience    Int?
  joining_date  DateTime?       @db.Date
  office_phone  String?         @db.VarChar(15)
  status        faculty_status? @default(ACTIVE)
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  updated_at    DateTime?       @default(now()) @db.Timestamp(0)
  department_id Int?
  attendance    attendance[]
  users         users           @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "faculty_ibfk_1")
  departments   departments?    @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_faculty_department")
  timetable     timetable[]

  @@index([department_id], map: "fk_faculty_department")
  @@index([user_id], map: "user_id")
}

model students {
  student_id       Int              @id @default(autoincrement())
  user_id          Int
  roll_number      String           @unique(map: "roll_number") @db.VarChar(30)
  admission_number String?          @unique(map: "admission_number") @db.VarChar(30)
  department       String           @db.VarChar(100)
  year             Int
  semester         Int
  section          String?          @db.VarChar(10)
  gender           String?          @db.VarChar(10)
  date_of_birth    DateTime?        @db.Date
  address          String?          @db.Text
  parent_name      String?          @db.VarChar(100)
  parent_phone     String?          @db.VarChar(15)
  blood_group      String?          @db.VarChar(5)
  admission_date   DateTime?        @db.Date
  status           students_status? @default(ACTIVE)
  created_at       DateTime?        @default(now()) @db.Timestamp(0)
  updated_at       DateTime?        @default(now()) @db.Timestamp(0)
  department_id    Int?
  attendance       attendance[]
  results          results[]
  departments      departments?     @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_student_department")
  users            users            @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "students_ibfk_1")

  @@index([department_id], map: "fk_student_department")
  @@index([user_id], map: "user_id")
}

model users {
  user_id       Int        @id @default(autoincrement())
  full_name     String     @db.VarChar(100)
  email         String     @unique(map: "email") @db.VarChar(100)
  password      String     @db.VarChar(255)
  role          users_role
  phone         String?    @db.VarChar(15)
  profile_image String?    @db.VarChar(255)
  is_active     Boolean?   @default(true)
  last_login    DateTime?  @db.Timestamp(0)
  created_at    DateTime?  @default(now()) @db.Timestamp(0)
  updated_at    DateTime?  @default(now()) @db.Timestamp(0)
  faculty       faculty[]
  students      students[]
}

model attendance {
  attendance_id   Int                @id @default(autoincrement())
  student_id      Int
  faculty_id      Int
  attendance_date DateTime           @db.Date
  status          attendance_status? @default(PRESENT)
  remarks         String?            @db.VarChar(255)
  created_at      DateTime?          @default(now()) @db.Timestamp(0)
  updated_at      DateTime?          @default(now()) @db.Timestamp(0)
  faculty         faculty            @relation(fields: [faculty_id], references: [faculty_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_attendance_faculty")
  students        students           @relation(fields: [student_id], references: [student_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_attendance_student")

  @@index([faculty_id], map: "fk_attendance_faculty")
  @@index([student_id], map: "fk_attendance_student")
}

model timetable {
  timetable_id  Int                   @id @default(autoincrement())
  subject_id    Int
  faculty_id    Int
  department_id Int
  day_of_week   timetable_day_of_week
  start_time    DateTime              @db.Time(0)
  end_time      DateTime              @db.Time(0)
  room_number   String?               @db.VarChar(20)
  created_at    DateTime?             @default(now()) @db.Timestamp(0)
  updated_at    DateTime?             @default(now()) @db.Timestamp(0)
  subjects      subjects              @relation(fields: [subject_id], references: [subject_id], onDelete: NoAction, onUpdate: NoAction, map: "timetable_ibfk_1")
  faculty       faculty               @relation(fields: [faculty_id], references: [faculty_id], onDelete: NoAction, onUpdate: NoAction, map: "timetable_ibfk_2")
  departments   departments           @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "timetable_ibfk_3")

  @@index([department_id], map: "department_id")
  @@index([faculty_id], map: "faculty_id")
  @@index([subject_id], map: "subject_id")
}

model examinations {
  exam_id     Int                    @id @default(autoincrement())
  subject_id  Int
  exam_name   String                 @db.VarChar(100)
  exam_type   examinations_exam_type
  exam_date   DateTime               @db.Date
  start_time  DateTime               @db.Time(0)
  end_time    DateTime               @db.Time(0)
  venue       String?                @db.VarChar(100)
  total_marks Int?                   @default(100)
  created_at  DateTime?              @default(now()) @db.Timestamp(0)
  updated_at  DateTime?              @default(now()) @db.Timestamp(0)
  subjects    subjects               @relation(fields: [subject_id], references: [subject_id], onDelete: NoAction, onUpdate: NoAction, map: "examinations_ibfk_1")
  results     results[]

  @@index([subject_id], map: "subject_id")
}

model results {
  result_id      Int                    @id @default(autoincrement())
  student_id     Int
  subject_id     Int
  exam_id        Int
  marks_obtained Decimal                @db.Decimal(5, 2)
  grade          String?                @db.VarChar(5)
  result_status  results_result_status? @default(PASS)
  remarks        String?                @db.VarChar(255)
  created_at     DateTime?              @default(now()) @db.Timestamp(0)
  updated_at     DateTime?              @default(now()) @db.Timestamp(0)
  examinations   examinations           @relation(fields: [exam_id], references: [exam_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_result_exam")
  students       students               @relation(fields: [student_id], references: [student_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_result_student")
  subjects       subjects               @relation(fields: [subject_id], references: [subject_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_result_subject")

  @@index([exam_id], map: "fk_result_exam")
  @@index([student_id], map: "fk_result_student")
  @@index([subject_id], map: "fk_result_subject")
}

enum users_role {
  ADMIN
  FACULTY
  STUDENT
}

enum faculty_status {
  ACTIVE
  INACTIVE
}

enum students_status {
  ACTIVE
  GRADUATED
  SUSPENDED
}

enum attendance_status {
  PRESENT
  ABSENT
  LATE
}

enum timetable_day_of_week {
  Monday
  Tuesday
  Wednesday
  Thursday
  Friday
  Saturday
}

enum examinations_exam_type {
  MID1
  MID2
  SEMESTER
  LAB
  PRACTICAL
}

enum results_result_status {
  PASS
  FAIL
}
